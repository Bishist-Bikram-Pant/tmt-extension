{
  "manifest_version": 3,
  "name": "Google TMT Translator",
  "version": "1.1.0",
  "description": "Translate web pages in real-time using Google TMT API. Supports English ↔ Nepali, English ↔ Tamang, and Nepali ↔ Tamang translations.",
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://tmt.ilprl.ku.edu.np/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/assets/icon-16.png",
      "48": "src/assets/icon-48.png",
      "128": "src/assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/scripts/content-script.js"],
      "run_at": "document_start"
    }
  ]
}
